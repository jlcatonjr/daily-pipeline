  "scenarios": [
    {
      "id": "routing-orchestrator-knows-all-experts",
      "category": "routing",
      "claim": "The orchestrator's agents: list includes every workstream expert, so it can route to each declared component.",
      "predicate": {
        "kind": "frontmatter-list-contains-all",
        "file": "orchestrator.agent.md",
        "field": "agents",
        "values": [
          "ingest-expert",
          "analysis-expert",
          "abstraction-expert",
          "integration-expert",
          "reporting-expert"
        ]
      }
    },
    {
      "id": "routing-expert-count-matches-components",
      "category": "routing",
      "claim": "Exactly 5 workstream-expert agent file(s) are emitted for 5 declared component(s).",
